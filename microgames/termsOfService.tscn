layout_mode = 0
offset_left = 19.0
offset_top = 9961.0
offset_right = 391.0
offset_bottom = 10008.0
bbcode_enabled = true
text = "[b]Article 15: Proportionality of Bean Stacking and Structural Integrity[/b][br]Should the V.T.M. possess any physical beans, they must not stack them in any configuration that exceeds a height-to-base ratio of 3.14159 to 1, a reference to Pi chosen specifically to force the V.T.M. to recall a half-forgotten mathematical constant and spend a moment trying to figure out the significance of it in bean stacking, and this \"P-Ratio\" must be maintained at all times, lest the resulting 'Bean Tower Collapse' (B.T.C.) trigger a mandatory, 24-hour liability assessment period, during which the V.T.M. is prohibited from doing anything other than internally debating whether the failure was due to insufficient structural integrity, improper foundational pulse selection, or a minor, undetectable seismic event caused by a distant, startled squirrel, thereby guaranteeing that the V.T.M. wastes an entire day contemplating bean physics, which is exactly the kind of highly unproductive activity the G.S.S.L. aims to promote through the rigorous enforcement of these absurdly complex terms. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

[node name="_Control_37" type="Control" parent="ScrollContainer/VBoxContainer"]
layout_mode = 2

[node name="TosArticle" type="RichTextLabel" parent="ScrollContainer/VBoxContainer/_Control_37"]
self_modulate = Color(0, 0, 0, 1)
show_behind_parent = true
layout_mode = 0
offset_left = 19.0
offset_top = 10528.0
offset_right = 391.0
offset_bottom = 10575.0
bbcode_enabled = true
text = "[b]Article 16: The Garbanzo/Chickpea Identity Crisis Clause[/b][br]The V.T.M. must recognize that \"Garbanzo\" and \"Chickpea\" are legally and gastronomically interchangeable terms, and any argument, debate, or even mild internal disagreement over the proper nomenclature shall be immediately grounds for a 'Linguistic Legume Audit' (L.L.A.), requiring the V.T.M. to mentally categorize every sentence in this Agreement as either predominantly 'Garbanzo-centric' or 'Chickpea-centric' based on the subtle semantic texture of the prose, a distinction that is entirely subjective and impossible to define, thereby forcing the V.T.M. into a state of deep, philosophical self-doubt regarding their linguistic competency and their understanding of bean-related synonyms, which in turn leads to a significant expenditure of mental processing power that serves no purpose other than to needlessly prolong the time it takes to finish reading this, yet another outrageously long and pointless paragraph. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

