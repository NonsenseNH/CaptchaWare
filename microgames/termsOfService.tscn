layout_mode = 0
offset_left = 19.0
offset_top = 4260.0
offset_right = 391.0
offset_bottom = 4307.0
bbcode_enabled = true
text = "[b]Article 6: Mandatory Bean Consumption Disclosure Period[/b][br]The V.T.M. is required to declare, within the temporal confines of the duration of reading this single paragraph, the exact time, location, and accompanying side dishes of their last three (3) significant bean-based meals, where a \"significant\" meal is defined as one containing more than 50 grams of beans, or one where a bean, however small, was the primary topic of conversation for more than three minutes, and this disclosure must be mentally registered and filed with the G.S.S.L.'s imaginary 'Department of Gastro-Leguminous Compliance' (D.G.L.C.), which exists only in the mind of the V.T.M. who is now actively engaging in this absurd mental exercise, thereby proving their non-robotic capacity for complying with utterly non-sensical, mandatory reporting requirements that serve no function other than to further distract the V.T.M. from the true goal of the BCG, which is, again, the immediate and unforgiving depletion of their available free time, a resource now clearly demonstrated to be ample, given the V.T.M.'s continued progress through this mind-numbing text, thereby confirming their suitability for accessing the highly sought-after, yet utterly trivial, resource protected by the Captcha. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

