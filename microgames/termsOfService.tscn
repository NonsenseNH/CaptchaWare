layout_mode = 0
offset_left = 19.0
offset_top = 8804.0
offset_right = 391.0
offset_bottom = 8851.0
bbcode_enabled = true
text = "[b]Article 13: Rules Pertaining to the Great Northern Bean's Paleness[/b][br]The V.T.M. must recognize that the Great Northern Bean’s pale color is not a sign of weakness or existential malaise, but rather a sophisticated aesthetic choice representing a 'Blanc Canvas of Gastronomic Potential,' and any derogatory remarks, spoken or thought, regarding the Great Northern Bean's hue (such as \"it looks a bit bland\") shall constitute a violation of the 'Good Faith Legume Appreciation' clause (see Article 88), incurring a mandatory penalty requiring the V.T.M. to immediately write a 14-line sonnet praising the subtle, creamy texture and light, nutty flavor of the Great Northern Bean, with the rhyme scheme AABB CCDD EEFF GG, and this sonnet must be mentally composed, revised, and structurally analyzed before the V.T.M. is permitted to move their eyes to the next article, adding a layer of compulsory, arbitrary creative endeavor to the already dense layer of compulsory, arbitrary legal interpretation, which is precisely what the G.S.S.L. intended when drafting this lengthy, time-siphoning document. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

