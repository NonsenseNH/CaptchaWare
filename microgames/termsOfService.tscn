offset_top = 4942.0
offset_right = 391.0
offset_bottom = 4989.0
bbcode_enabled = true
text = "[b]Article 7: The Unintentional Doctrine of Refried Beans[/b][br]Any agreement, contract, or verbal understanding made by the V.T.M. within forty-eight (48) hours following the ingestion of refried beans is hereby deemed null and void, as the G.S.S.L. acknowledges the scientifically proven, yet legally ignored, phenomenon of \"Post-Refried Cognitive Dissonance\" (P.R.C.D.), which renders the V.T.M. temporarily incapable of making rational, long-term decisions, often leading to impulsive purchases of bean-related merchandise or the sudden desire to enroll in an online course about the history of the tlacoyo, and the G.S.S.L. takes no responsibility for the V.T.M.'s questionable life choices during a P.R.C.D. episode, provided that the V.T.M. can successfully prove their refried bean consumption via a detailed, timestamped photograph of the empty serving vessel and a 500-word reflective essay on the emotional and psychological journey of consuming heavily processed legumes, which, naturally, must be completed and mentally submitted during the P.R.C.D. period, adding another layer of complex, pointless bureaucracy to an already over-complicated clause designed merely to occupy another chunk of the V.T.M.'s declining attention span. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

