offset_bottom = 3556.0
bbcode_enabled = true
text = "[b]Article 5: Classification and Licensing of the Pinto Bean Pattern[/b][br]The speckled pattern found on the Phaseolus Vulgaris 'Pinto' bean is hereby declared the proprietary intellectual property of the G.S.S.L., protected under the Treaty of Bucharest (which, for the record, has absolutely nothing to do with beans, but sounds important), and the V.T.M. is granted a non-exclusive, non-transferable, revocable, and highly conditional license to view this pattern, provided they do not attempt to replicate it on any surface, including, but not limited to, clothing, ceramics, abstract paintings, or the back of a utility bill, without first filing a 4,000-page application detailing their artistic intent, the exact shade of beige they plan to use, and a complete psychiatric evaluation confirming their mental stability despite their choice of subject matter, and the license is automatically revoked if the V.T.M. confuses the Pinto pattern with that of the Cranberry Bean, a subtle but critical distinction that the G.S.S.L. can detect via proprietary 'Spectral Legume Analysis' (S.L.A.) technology embedded within this text, which tracks the precise moment of reader confusion, ensuring compliance with the ridiculously high and irrelevant standards of pattern recognition set forth herein, all while the V.T.M. is still trying to figure out what a \"non-exclusive, non-transferable\" license actually means in the context of bean spots. "
fit_content = true
scroll_active = false
shortcut_keys_enabled = false

[node name="_Control_17" type="Control" parent="ScrollContainer/VBoxContainer"]
layout_mode = 2

